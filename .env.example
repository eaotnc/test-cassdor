# Copy this file to .env and adjust values as needed.

# App PostgreSQL
APP_POSTGRES_DB=acme
APP_POSTGRES_USER=acme
APP_POSTGRES_PASSWORD=acme
APP_POSTGRES_PORT=5434
DATABASE_URL=postgresql://acme:acme@localhost:5434/acme

# Casdoor (IAM / auth)
CASDOOR_PORT=8000
CASDOOR_URL=http://localhost:8000
CASDOOR_CLIENT_ID=acme-back-office
CASDOOR_CLIENT_SECRET=back-office-secret-change-me
CASDOOR_ORGANIZATION=acme

# API (NestJS)
PORT=4000
